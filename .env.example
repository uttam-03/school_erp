# ============================================================
# EduCore ERP - Environment Variables
# ============================================================
# LOCAL USE:
#   1. Is file ki copy banao → naam do ".env"
#   2. Sirf SECRET_KEY fill karo
#   3. DATABASE_URL khali chhodo (SQLite auto use hoga)
#
# RENDER USE:
#   Render Dashboard → Environment mein ye sab set karo
# ============================================================

# ── Django ──────────────────────────────────────────────────
SECRET_KEY=school-erp-secret-key-change-this-to-random
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ────────────────────────────────────────────────
# LOCAL: Khali chhodo - SQLite automatically use hoga
# RENDER: Render PostgreSQL ka URL yahan paste karo
DATABASE_URL=

# ── Render (Sirf Render Dashboard mein set karo) ────────────
# RENDER_EXTERNAL_HOSTNAME=yourapp.onrender.com
# DEBUG=False
